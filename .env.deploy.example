# THERMOps Traefik 배포 환경 변수 예시
# 사용: cp .env.deploy.example .env.deploy 후 값 수정
# 실제 비밀번호를 커밋하지 마세요 (.env.deploy 는 .gitignore 대상)

# --- Compose / Traefik ---
COMPOSE_PROJECT_NAME=thermops
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt

# 공개 도메인 (DNS A레코드 1개)
THERMOPS_HOST=thermops.openlink.kr

# --- Frontend (빌드 시 bake-in) ---
# 같은 도메인 상대 경로 — 브라우저 요청: https://thermops.openlink.kr/api/v1/...
VITE_API_BASE_URL=/api/v1
# Mock UI 권한: ADMIN | OPERATOR | VIEWER (실제 인증 아님)
VITE_USER_ROLE=OPERATOR

# --- Backend ---
BACKEND_CORS_ORIGINS=https://thermops.openlink.kr

# --- PostgreSQL ---
POSTGRES_DB=thermops
POSTGRES_USER=thermops
# @ # % 등 특수문자 사용 가능 (backend/airflow/mlflow 가 URL 인코딩 처리)
POSTGRES_PASSWORD=change-me-strong-password

# --- Airflow (내부 통신, 기본 외부 비공개) ---
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=change-me-airflow-password
AIRFLOW_BASE_URL=http://airflow:8080

# --- MinIO / MLflow (내부 통신) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-minio-password
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Clean reset 스크립트 ---
THERMOPS_DEPLOY_ENV=clean

# --- R10-S10 Run Due Worker (run-due-worker service) ---
THERMOOPS_RUN_DUE_WORKER_ENABLED=true
THERMOOPS_RUN_DUE_WORKER_NAME=run-due-worker-1
THERMOOPS_RUN_DUE_WORKER_MODE=loop
THERMOOPS_RUN_DUE_POLL_INTERVAL_SECONDS=60
THERMOOPS_RUN_DUE_LOCK_TTL_SECONDS=120
THERMOOPS_RUN_DUE_MAX_BATCH_SIZE=20
THERMOOPS_RUN_DUE_FAIL_FAST=false
THERMOOPS_RUN_DUE_NOTIFICATION_ENABLED=true
THERMOOPS_RUN_DUE_GRACEFUL_TIMEOUT_SECONDS=30
THERMOOPS_RUN_DUE_LOG_LEVEL=INFO

# --- R11-S7-6 Visual Pipeline Run Worker (vp-run-worker service) ---
# 운영 권장: worker enqueue + vp-run-worker loop (POST /runs는 PENDING만 생성)
THERMOOPS_VP_RUN_EXECUTOR=worker
THERMOOPS_VP_RUN_WORKER_ENABLED=true
THERMOOPS_VP_RUN_WORKER_MODE=loop
THERMOOPS_VP_RUN_WORKER_POLL_INTERVAL_SECONDS=5
# lock TTL: 긴 run_load를 고려해 300s 권장 (만료 시 ops stuck RUNNING_LOCK_EXPIRED)
THERMOOPS_VP_RUN_WORKER_LOCK_TTL_SECONDS=300
THERMOOPS_VP_RUN_WORKER_MAX_BATCH_SIZE=1
THERMOOPS_VP_RUN_WORKER_ID=
THERMOOPS_VP_RUN_WORKER_LOG_LEVEL=INFO

# R11-S7-8 Visual Pipeline Schedule Activation + vp-schedule-worker
THERMOOPS_VP_SCHEDULE_ACTIVATION_ENABLED=true
THERMOOPS_VP_SCHEDULE_WORKER_ENABLED=true
THERMOOPS_VP_SCHEDULE_WORKER_MODE=loop
THERMOOPS_VP_SCHEDULE_WORKER_POLL_INTERVAL_SECONDS=30
THERMOOPS_VP_SCHEDULE_WORKER_MAX_BATCH_SIZE=10
THERMOOPS_VP_SCHEDULE_WORKER_ID=
THERMOOPS_VP_SCHEDULE_MIN_INTERVAL_SECONDS=300
THERMOOPS_VP_SCHEDULE_WORKER_LOG_LEVEL=INFO

# R11-S7-10 운영 점검
# GET /api/v1/visual-pipeline-ops/summary
# GET /api/v1/visual-pipeline-ops/stuck-runs
# python scripts/manage_visual_pipeline_ops.py mark-failed --dry-run
# python scripts/manage_visual_pipeline_ops.py mark-failed --apply --reason "manual ops cleanup"

# R11-S7-14 Admin Action PoC (Auth 대체 아님 — 기능 노출 안전장치)
# 기본 false. 운영 적용 시 명시적으로 true로 전환.
# Set true only for controlled Admin Action PoC/testing.
THERMOOPS_VP_ADMIN_ACTIONS_ENABLED=false

# --- Optional admin exposure (기본 비활성, CNAME 사용 — A레코드 추가 없음) ---
ENABLE_ADMIN_PUBLIC=false
# AIRFLOW_HOST=airflow.thermops.openlink.kr
# MLFLOW_HOST=mlflow.thermops.openlink.kr
# MINIO_HOST=minio.thermops.openlink.kr
# htpasswd -nb admin 'your-password' 결과 (Traefik basic auth)
# TRAEFIK_BASIC_AUTH_USERS=admin:$$apr1$$...
