# PostgreSQL
POSTGRES_USER=thermops
POSTGRES_PASSWORD=thermops
POSTGRES_DB=thermops

# Backend
DATABASE_URL=postgresql+asyncpg://thermops:thermops@localhost:5432/thermops
MLFLOW_TRACKING_URI=http://localhost:5000
CORS_ORIGINS=http://localhost:5173

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
# ADMIN | OPERATOR | VIEWER (기본: VIEWER, docker-compose는 ADMIN)
VITE_USER_ROLE=ADMIN
