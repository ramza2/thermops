# PostgreSQL
POSTGRES_USER=thermops
POSTGRES_PASSWORD=thermops
POSTGRES_DB=thermops

# Backend
DATABASE_URL=postgresql+asyncpg://thermops:thermops@localhost:5432/thermops
MLFLOW_TRACKING_URI=http://localhost:5000
CORS_ORIGINS=http://localhost:5173
# CSV file_path 해석 기준 (Docker: /workspace, 로컬: 미설정 시 repo 루트 자동)
THERMOPS_PROJECT_ROOT=

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
# Mock UI 권한 (실제 인증 아님). ADMIN | OPERATOR | VIEWER
VITE_USER_ROLE=ADMIN

# R10-S10 Run Due Worker (Docker run-due-worker service)
THERMOOPS_RUN_DUE_WORKER_ENABLED=false
THERMOOPS_RUN_DUE_WORKER_NAME=run-due-worker-1
THERMOOPS_RUN_DUE_WORKER_MODE=loop
THERMOOPS_RUN_DUE_POLL_INTERVAL_SECONDS=60
THERMOOPS_RUN_DUE_LOCK_TTL_SECONDS=120
THERMOOPS_RUN_DUE_MAX_BATCH_SIZE=20
THERMOOPS_RUN_DUE_FAIL_FAST=false
THERMOOPS_RUN_DUE_NOTIFICATION_ENABLED=true
THERMOOPS_RUN_DUE_GRACEFUL_TIMEOUT_SECONDS=30
THERMOOPS_RUN_DUE_LOG_LEVEL=INFO

# R11-S7-6 Visual Pipeline Run Worker (Option C)
# background_tasks = S7-3 in-process (default for local); worker = vp-run-worker claim
THERMOOPS_VP_RUN_EXECUTOR=background_tasks
THERMOOPS_VP_RUN_WORKER_ENABLED=false
THERMOOPS_VP_RUN_WORKER_MODE=loop
THERMOOPS_VP_RUN_WORKER_POLL_INTERVAL_SECONDS=5
THERMOOPS_VP_RUN_WORKER_LOCK_TTL_SECONDS=120
THERMOOPS_VP_RUN_WORKER_MAX_BATCH_SIZE=1
THERMOOPS_VP_RUN_WORKER_ID=
THERMOOPS_VP_RUN_WORKER_LOG_LEVEL=INFO

# R11-S7-8 Visual Pipeline Schedule Activation
THERMOOPS_VP_SCHEDULE_ACTIVATION_ENABLED=false
THERMOOPS_VP_SCHEDULE_WORKER_ENABLED=false
THERMOOPS_VP_SCHEDULE_WORKER_MODE=loop
THERMOOPS_VP_SCHEDULE_WORKER_POLL_INTERVAL_SECONDS=30
THERMOOPS_VP_SCHEDULE_WORKER_MAX_BATCH_SIZE=10
THERMOOPS_VP_SCHEDULE_WORKER_ID=
THERMOOPS_VP_SCHEDULE_MIN_INTERVAL_SECONDS=300
THERMOOPS_VP_SCHEDULE_WORKER_LOG_LEVEL=INFO
